# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# X data provider: 'twitterapi_io' (default) | 'x_official'
X_PROVIDER=twitterapi_io
TWITTERAPI_IO_KEY=

# X OAuth 2.0 (clipper sign-in)
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/x/callback

# Email (magic-link delivery via Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=auth@yourdomain.com

# Cron secret (sent as x-cron-secret header)
CRON_SECRET=

# Clips tracking API key. Static bearer secret for the read-only
# GET/POST /api/admin/clips endpoint used by the deliverable-tracking app.
# Use any long random string and set the same value in Vercel.
CLIPS_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Solana payouts (admin-side USDC sends)
# Network: 'mainnet-beta' (default) or 'devnet'
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
# Server-side RPC. REQUIRED for the admin payout panel to work — Solana's
# public RPC (api.mainnet-beta.solana.com) returns 403 on token-scan methods.
# Sign up for a free Helius/QuickNode/Triton/Alchemy key and paste the URL here.
# The browser hits /api/solana/rpc which proxies to this URL, so the key is
# never exposed to clients.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Optional: override the browser RPC URL to skip the proxy and hit a public
# endpoint directly. Leave unset to use the proxy (recommended).
# NEXT_PUBLIC_SOLANA_RPC_URL=
# Optional: override the USDC mint (defaults to mainnet USDC).
NEXT_PUBLIC_USDC_MINT=
